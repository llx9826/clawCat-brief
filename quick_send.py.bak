<style>
body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 16px; line-height: 1.7; color: #1c1917; background: #f5f5f0; margin: 0; padding: 0; }
.container { max-width: 720px; margin: 0 auto; padding: 20px; }
header { background: linear-gradient(135deg, #292524 0%, #1c1917 100%); color: white; padding: 40px 32px; border-radius: 20px; margin-bottom: 24px; text-align: center; }
