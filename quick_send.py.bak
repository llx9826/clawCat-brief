#!/usr/bin/env python3
"""快速生成色彩版周报"""

from core.sender import EmailSender

html = '''<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
